# ============================================
# CONFIGURACIÓN MISTRAL OCR
# ============================================

# ✅ REQUERIDO: API Key de Mistral
# Obtén en: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Modelo a usar para OCR (recomendado para visión)
MISTRAL_MODEL=pixtral-12b-2409

# Umbral mínimo de calidad para procesar con OCR
# Valores entre 0.0 y 1.0
# 0.4-0.5 = Flexible (acepta borroso)
# 0.6-0.7 = Moderado
# 0.8+ = Estricto
OCR_MIN_QUALITY=0.5

# ============================================
# CONFIGURACIÓN EXISTENTE (no modificar)
# ============================================

# Base de datos
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google Drive
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret

# Gmail SMTP
SMTP_EMAIL=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PORT=465

# Admin
ADMIN_TOKEN=your_secure_token
